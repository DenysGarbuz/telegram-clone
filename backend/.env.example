# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Runtime
NODE_ENV=development
PORT=3003

# MongoDB connection string. Atlas example:
# mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URL=

# JWT signing secret. Generate a strong one:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_PRIVATE_KEY=

# Origin of the frontend (no trailing slash). Used by CORS + Socket.IO.
FRONTEND_URL=http://localhost:3000

# Send Set-Cookie with `Secure` flag (set to `true` in production over HTTPS).
COOKIE_SECURE=false

# AWS S3 (chat attachments). The IAM user needs s3:PutObject + s3:GetObject
# on the bucket below.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=
